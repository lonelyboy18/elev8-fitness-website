# Secrets for `docker compose up` (docker-compose.yml reads a `.env` file from this same
# directory automatically). Copy this to `.env` and fill in real values before running the
# stack for anything beyond local rehearsal — the compose file's defaults are placeholders.

# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_min_16_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_16_chars
REFRESH_TOKEN_HASH_SECRET=change_me_hash_secret_min_16_chars

# Razorpay — required for real payments; the app will refuse to start with these
# placeholders if NODE_ENV=production (see server/src/config/env.ts)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_HERE
