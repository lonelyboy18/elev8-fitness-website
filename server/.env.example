NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# PostgreSQL — matches docker-compose.yml's postgres service by default
DATABASE_URL=postgresql://elev8:elev8_dev_password@localhost:5432/elev8_db?schema=public

# JWT secrets — generate with `openssl rand -hex 32`
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
# HMAC key used to hash refresh-token identifiers before they touch the database — must
# differ from JWT_REFRESH_SECRET (defense in depth: a leaked hash secret alone can't forge tokens)
REFRESH_TOKEN_HASH_SECRET=dev_refresh_hash_secret_change_me
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

# Razorpay
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_HERE

# Set true behind HTTPS in production
COOKIE_SECURE=false
